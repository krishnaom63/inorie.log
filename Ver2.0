<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Inorie.log｜軍師に聞く</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700&family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --gold:#c8a84b;--gold2:#e8c86a;--dark:#080810;--dark2:#0f0f1a;
  --dark3:#1a1a2e;--dark4:#1e1e35;--text:#f0ede8;--muted:#888;
  --green:#4caf50;--red:#e57373;--blue:#5b8dd9;--purple:#9b59b6;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow-x:hidden}
body{
  background:var(--dark);color:var(--text);
  font-family:'Noto Sans JP',sans-serif;
  min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;padding:0 20px;
}

/* 背景パーティクル */
.bg{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;overflow:hidden}
.bg::before{content:’’;position:absolute;top:-50%;left:-50%;width:200%;height:200%;
background:radial-gradient(ellipse at 30% 20%, rgba(200,168,75,0.06) 0%, transparent 50%),
radial-gradient(ellipse at 70% 80%, rgba(91,61,138,0.06) 0%, transparent 50%);
animation:bgPulse 8s ease-in-out infinite alternate}
@keyframes bgPulse{from{transform:scale(1)}to{transform:scale(1.1)}}

.screen{
position:relative;z-index:1;
width:100%;max-width:400px;
display:flex;flex-direction:column;align-items:center;
padding:40px 0 60px;
}
.hidden{display:none!important}

/* ロゴ */
.logo-wrap{text-align:center;margin-bottom:32px}
.logo-en{font-size:11px;letter-spacing:8px;color:var(–gold);font-family:‘Noto Serif JP’,serif;opacity:.8}
.logo-line{width:40px;height:1px;background:linear-gradient(90deg,transparent,var(–gold),transparent);margin:8px auto}
.logo-ja{font-size:36px;font-weight:700;font-family:‘Noto Serif JP’,serif;
background:linear-gradient(135deg,var(–text) 0%,var(–gold2) 50%,var(–text) 100%);
-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
letter-spacing:4px}
.logo-sub{font-size:12px;color:var(–muted);margin-top:8px;letter-spacing:2px}

/* ボタン */
.btn{
width:100%;padding:18px;border-radius:16px;border:none;
font-size:15px;font-weight:700;cursor:pointer;margin-bottom:12px;
font-family:‘Noto Sans JP’,sans-serif;letter-spacing:1px;
transition:all .2s;position:relative;overflow:hidden;
}
.btn:active{transform:scale(.97)}
.btn-gold{
background:linear-gradient(135deg,#b8942a,var(–gold),#d4aa50);
color:#0a0a0a;box-shadow:0 4px 20px rgba(200,168,75,.35);
}
.btn-gold::after{content:’’;position:absolute;top:0;left:-100%;width:100%;height:100%;
background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);
transition:left .5s}
.btn-gold:active::after{left:100%}
.btn-outline{
background:transparent;color:var(–gold);
border:1.5px solid rgba(200,168,75,.5);
backdrop-filter:blur(10px);
}
.btn-ghost{
background:rgba(255,255,255,.04);color:var(–muted);
border:1px solid rgba(255,255,255,.08);margin-top:4px;font-size:13px;
}
.btn-danger{background:linear-gradient(135deg,#c0392b,var(–red));color:#fff;box-shadow:0 4px 16px rgba(227,115,115,.3)}
.btn-copy{background:var(–dark4);color:var(–gold);border:1px solid rgba(200,168,75,.4)}
.btn-purple{background:linear-gradient(135deg,#7d3c98,var(–purple));color:#fff;box-shadow:0 4px 16px rgba(155,89,182,.3)}

/* エラー */
.error{color:var(–red);font-size:12px;text-align:center;margin-bottom:14px;
width:100%;padding:10px;background:rgba(227,115,115,.1);border-radius:8px;
border:1px solid rgba(227,115,115,.2)}

/* 波形 */
.wave-wrap{display:flex;align-items:center;justify-content:center;gap:5px;height:64px;margin-bottom:24px}
.bar{width:5px;border-radius:10px;background:linear-gradient(180deg,var(–gold2),var(–gold));
height:6px;transition:height .1s}
.bar.active{animation:waveAnim .5s ease-in-out infinite alternate}
.bar:nth-child(1).active{animation-delay:0s;animation-duration:.45s}
.bar:nth-child(2).active{animation-delay:.08s;animation-duration:.5s}
.bar:nth-child(3).active{animation-delay:.15s;animation-duration:.4s}
.bar:nth-child(4).active{animation-delay:.22s;animation-duration:.55s}
.bar:nth-child(5).active{animation-delay:.1s;animation-duration:.42s}
.bar:nth-child(6).active{animation-delay:.18s;animation-duration:.48s}
.bar:nth-child(7).active{animation-delay:.05s;animation-duration:.52s}
.bar:nth-child(8).active{animation-delay:.12s;animation-duration:.44s}
.bar:nth-child(9).active{animation-delay:.2s;animation-duration:.5s}
@keyframes waveAnim{from{height:6px}to{height:48px}}

/* 文字起こし */
.transcript{
width:100%;background:rgba(255,255,255,.03);
border:1px solid rgba(255,255,255,.08);
border-radius:14px;padding:16px;min-height:100px;
font-size:14px;color:#bbb;line-height:1.9;margin-bottom:20px;
backdrop-filter:blur(10px);
}

/* ローディング */
.loading-icon{font-size:52px;margin-bottom:20px;animation:float 2s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.thinking{
font-size:16px;color:var(–gold);margin-bottom:20px;
text-align:center;min-height:28px;font-family:‘Noto Serif JP’,serif;
letter-spacing:1px;
}
.dots{display:flex;gap:8px;margin-top:4px}
.dot{width:8px;height:8px;border-radius:50%;
background:linear-gradient(135deg,var(–gold2),var(–gold));
animation:dotAnim .6s ease-in-out infinite alternate}
.dot:nth-child(2){animation-delay:.2s}
.dot:nth-child(3){animation-delay:.4s}
@keyframes dotAnim{from{opacity:.2;transform:scale(.7)}to{opacity:1;transform:scale(1.3)}}

/* カード */
.cards{width:100%;display:flex;flex-direction:column;gap:12px;margin-bottom:20px}
.card{
background:linear-gradient(135deg,var(–dark3),var(–dark4));
border-radius:16px;padding:18px 20px;
border:1px solid rgba(255,255,255,.06);
border-left:3px solid var(–gold);
box-shadow:0 4px 20px rgba(0,0,0,.3);
animation:cardIn .4s ease both;
}
.card:nth-child(1){animation-delay:.05s}
.card:nth-child(2){animation-delay:.15s}
.card:nth-child(3){animation-delay:.25s}
.card:nth-child(4){animation-delay:.35s}
@keyframes cardIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.card.omote{border-left-color:var(–green)}
.card.ura{border-left-color:var(–red)}
.card.next{border-left-color:var(–blue)}
.card.shintak{border-left-color:var(–purple)}
.card-label{font-size:10px;letter-spacing:3px;color:var(–gold);margin-bottom:6px;
font-family:‘Noto Serif JP’,serif;display:flex;align-items:center;gap:6px}
.card.omote .card-label{color:var(–green)}
.card.ura .card-label{color:var(–red)}
.card.next .card-label{color:var(–blue)}
.card.shintak .card-label{color:var(–purple)}
.card-body{font-size:14px;color:#d8d4d0;line-height:1.9;white-space:pre-wrap}

/* テキストエリア */
textarea{
width:100%;height:150px;
background:rgba(255,255,255,.04);
color:var(–text);
border:1.5px solid rgba(200,168,75,.3);
border-radius:14px;padding:14px;
font-size:14px;line-height:1.8;resize:none;
font-family:‘Noto Sans JP’,sans-serif;
margin-bottom:14px;backdrop-filter:blur(10px);
transition:border-color .2s;
}
textarea:focus{outline:none;border-color:var(–gold)}

/* マイク許可 */
.mic-guide{
width:100%;background:rgba(200,168,75,.08);
border:1px solid rgba(200,168,75,.2);
border-radius:14px;padding:16px;margin-bottom:16px;text-align:center;
}
.mic-guide p{font-size:13px;color:#bbb;line-height:1.8}
.mic-guide strong{color:var(–gold)}

/* セクション区切り */
.divider{width:100%;display:flex;align-items:center;gap:12px;margin:4px 0 16px;opacity:.4}
.divider::before,.divider::after{content:’’;flex:1;height:1px;background:rgba(255,255,255,.1)}
.divider span{font-size:11px;color:var(–muted);letter-spacing:2px}

/* ページ上部固定 */
.page-top{justify-content:flex-start;padding-top:50px}

/* 録音ステータス */
.rec-status{
display:flex;align-items:center;gap:8px;
font-size:12px;color:var(–red);letter-spacing:2px;
margin-bottom:16px;font-family:‘Noto Serif JP’,serif;
}
.rec-dot{width:8px;height:8px;border-radius:50%;background:var(–red);
animation:recBlink 1s ease-in-out infinite}
@keyframes recBlink{0%,100%{opacity:1}50%{opacity:.2}}

/* 神託専用スタイル */
.shintak-bg{
position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;
background:radial-gradient(ellipse at 50% 30%, rgba(155,89,182,.08) 0%, transparent 60%);
}
.shintak-icon{font-size:52px;margin-bottom:12px;animation:float 3s ease-in-out infinite}
</style>

</head>
<body>
<div class="bg"></div>

<!-- ホーム -->

<div id="home" class="screen">
  <div class="logo-wrap">
    <p class="logo-en">INORIE . LOG</p>
    <div class="logo-line"></div>
    <h1 class="logo-ja">軍師に聞く</h1>
    <p class="logo-sub">声を記録し、AIが戦略を授ける</p>
  </div>
  <p id="homeError" class="error hidden"></p>
  <button class="btn btn-gold" onclick="startRec('gunshi')">🎙️ &nbsp;録音を始める</button>
  <button class="btn btn-purple" onclick="startRec('shintak')">⛩️ &nbsp;神託モード</button>
None
</div>

None

<!-- マイク許可ガイド -->

<div id="micGuide" class="screen hidden">
  <div class="logo-wrap" style="margin-bottom:20px">
    <p class="logo-en">INORIE . LOG</p>
    <div class="logo-line"></div>
  </div>
  <div style="font-size:48px;margin-bottom:16px;text-align:center">🎙️</div>
  <div class="mic-guide">
    <p><strong>マイクの許可が必要です</strong><br><br>
    「許可」または「Allow」をタップしてください。<br><br>
    許可が出ない場合は<br>
    <strong>設定 → Safari → マイク → 許可</strong><br>
    に変更してください。</p>
  </div>
  <button class="btn btn-gold" onclick="retryMic()">🎙️ &nbsp;もう一度試す</button>
  <button class="btn btn-ghost" onclick="show('home')">← &nbsp;戻る</button>
</div>

<!-- 録音中（軍師） -->

<div id="recording" class="screen hidden">
  <div class="logo-wrap" style="margin-bottom:16px">
    <p class="logo-en">RECORDING</p>
    <div class="logo-line"></div>
  </div>
  <div class="rec-status"><div class="rec-dot"></div>録音中</div>
  <div class="wave-wrap" id="wave">
    <div class="bar" id="b1"></div><div class="bar" id="b2"></div>
    <div class="bar" id="b3"></div><div class="bar" id="b4"></div>
    <div class="bar" id="b5"></div><div class="bar" id="b6"></div>
    <div class="bar" id="b7"></div><div class="bar" id="b8"></div>
    <div class="bar" id="b9"></div>
  </div>
  <div class="transcript" id="recTranscript">話し始めてください…</div>
  <button class="btn btn-danger" onclick="stopRec('gunshi')">⏹ &nbsp;停止して軍師に解析させる</button>
  <button class="btn btn-ghost" onclick="cancelRec()">キャンセル</button>
</div>

<!-- 録音中（神託） -->

<div id="shintakRec" class="screen hidden">
  <div class="shintak-bg"></div>
  <div class="shintak-icon">⛩️</div>
  <div class="logo-wrap" style="margin-bottom:16px">
    <p class="logo-en" style="color:var(--purple)">SHINTAK MODE</p>
    <div class="logo-line" style="background:linear-gradient(90deg,transparent,var(--purple),transparent)"></div>
    <p style="font-size:13px;color:#bbb;margin-top:8px;text-align:center;line-height:1.8">
      悩みや祈りを、声に出してください<br>
      <span style="color:var(--purple);font-size:11px">神様があなたの声を聴いています</span>
    </p>
  </div>
  <div class="rec-status" style="color:var(--purple)">
    <div class="rec-dot" style="background:var(--purple)"></div>祈りを記録中
  </div>
  <div class="wave-wrap">
    <div class="bar" id="sb1" style="background:linear-gradient(180deg,#c39bd3,var(--purple))"></div>
    <div class="bar" id="sb2" style="background:linear-gradient(180deg,#c39bd3,var(--purple))"></div>
    <div class="bar" id="sb3" style="background:linear-gradient(180deg,#c39bd3,var(--purple))"></div>
    <div class="bar" id="sb4" style="background:linear-gradient(180deg,#c39bd3,var(--purple))"></div>
    <div class="bar" id="sb5" style="background:linear-gradient(180deg,#c39bd3,var(--purple))"></div>
    <div class="bar" id="sb6" style="background:linear-gradient(180deg,#c39bd3,var(--purple))"></div>
    <div class="bar" id="sb7" style="background:linear-gradient(180deg,#c39bd3,var(--purple))"></div>
  </div>
  <div class="transcript" id="shintakTranscript" style="border-color:rgba(155,89,182,.3)">話し始めてください…</div>
  <button class="btn btn-purple" onclick="stopRec('shintak')">⛩️ &nbsp;神託を受け取る</button>
  <button class="btn btn-ghost" onclick="cancelRec()">キャンセル</button>
</div>

<!-- 解析中（軍師） -->

<div id="analyzing" class="screen hidden">
  <div class="loading-icon">🏯</div>
  <p class="thinking" id="thinkingText">軍師が思考中…</p>
  <div class="dots"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
  <p style="font-size:11px;color:rgba(255,255,255,.2);margin-top:24px;letter-spacing:2px">ANALYZING...</p>
</div>

<!-- 解析中（神託） -->

<div id="shintakAnalyzing" class="screen hidden">
  <div class="shintak-bg"></div>
  <div class="loading-icon">⛩️</div>
  <p class="thinking" id="shintakThinkingText" style="color:var(--purple)">神様に繋いでいます…</p>
  <div class="dots">
    <div class="dot" style="background:var(--purple)"></div>
    <div class="dot" style="background:var(--purple)"></div>
    <div class="dot" style="background:var(--purple)"></div>
  </div>
  <p style="font-size:11px;color:rgba(155,89,182,.3);margin-top:24px;letter-spacing:2px">CONNECTING...</p>
</div>

<!-- 結果（軍師） -->

<div id="result" class="screen page-top hidden">
  <div class="logo-wrap" style="margin-bottom:20px">
    <p class="logo-en">GUNSHI ANALYSIS</p>
    <div class="logo-line"></div>
    <h2 style="font-size:18px;color:var(--gold);font-family:'Noto Serif JP',serif;margin-top:8px">軍師解析結果</h2>
  </div>
  <div class="cards">
    <div class="card">
      <div class="card-label">📋 &nbsp;要約</div>
      <div class="card-body" id="resSummary"></div>
    </div>
    <div class="card omote">
      <div class="card-label">⚔️ &nbsp;表の策 ─ 王道の戦略</div>
      <div class="card-body" id="resOmote"></div>
    </div>
    <div class="card ura">
      <div class="card-label">🗡️ &nbsp;裏の策 ─ 別視点の戦略</div>
      <div class="card-body" id="resUra"></div>
    </div>
    <div class="card next">
      <div class="card-label">✅ &nbsp;ネクストアクション</div>
      <div class="card-body" id="resNext"></div>
    </div>
  </div>
  <button class="btn btn-gold" id="copyBtn" onclick="copyAll()">📋 &nbsp;全部コピーする</button>
  <button class="btn btn-ghost" onclick="reset()">🔄 &nbsp;もう一度録音する</button>
</div>

<!-- 結果（神託） -->

<div id="shintakResult" class="screen hidden">
  <div class="shintak-bg"></div>
  <div class="logo-wrap" style="margin-bottom:20px">
    <p class="logo-en" style="color:var(--purple)">ORACLE MESSAGE</p>
    <div class="logo-line" style="background:linear-gradient(90deg,transparent,var(--purple),transparent)"></div>
    <h2 style="font-size:18px;color:var(--purple);font-family:'Noto Serif JP',serif;margin-top:8px">神 託</h2>
  </div>
  <div class="cards">
    <div class="card shintak">
      <div class="card-label">⛩️ &nbsp;神様からのメッセージ</div>
      <div class="card-body" id="shintakMsg" style="font-family:'Noto Serif JP',serif;font-size:15px;line-height:2.1;color:#e0d8f0"></div>
    </div>
  </div>
  <button class="btn btn-copy" id="shintakCopyBtn" onclick="copyShintaku()">📋 &nbsp;コピーする</button>
  <button class="btn btn-ghost" onclick="reset()">🏠 &nbsp;ホームに戻る</button>
</div>

<script>
const API = "https://api.anthropic.com/v1/messages";
let recog = null, currentMode = "gunshi", transcript = "", retryMode = "gunshi";
let thinkTimer = null;

const gunshiPhrases = [
  "軍師が思考中…","戦局を見極めている…","策を練っている…",
  "智謀を巡らせている…","深く考察している…","勝機を探っている…"
];
const shintakPhrases = [
  "神様に繋いでいます…","祈りを受け取っています…",
  "神託を紡いでいます…","天の声を聴いています…","光が降りてきています…"
];

function show(id){
  const screens = ["home","textInput","micGuide","recording","shintakRec",
    "analyzing","shintakAnalyzing","result","shintakResult"];
  screens.forEach(s => {
    const el = document.getElementById(s);
    if(el) el.classList.add("hidden");
  });
  const target = document.getElementById(id);
  if(target){
    target.classList.remove("hidden");
    window.scrollTo({top:0,behavior:"smooth"});
  }
}

function setWave(prefix, active, count=9){
  for(let i=1;i<=count;i++){
    const b = document.getElementById(prefix+i);
    if(b){ active ? b.classList.add("active") : b.classList.remove("active"); }
  }
}

function startRec(mode){
  currentMode = mode;
  retryMode = mode;
  transcript = "";

  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if(!SR){
    showError("homeError","このブラウザは音声認識に対応していません。Chromeをお試しください。");
    return;
  }

  recog = new SR();
  recog.lang = "ja-JP";
  recog.continuous = true;
  recog.interimResults = true;
  recog.maxAlternatives = 1;

  recog.onstart = () => {
    show(mode === "shintak" ? "shintakRec" : "recording");
    setWave(mode === "shintak" ? "sb" : "b", true, mode === "shintak" ? 7 : 9);
  };

  recog.onresult = (e) => {
    let t = "";
    for(let i = 0; i < e.results.length; i++) t += e.results[i][0].transcript;
    transcript = t;
    const el = document.getElementById(mode === "shintak" ? "shintakTranscript" : "recTranscript");
    if(el) el.textContent = t || "話し始めてください…";
  };

  recog.onerror = (e) => {
    setWave("b", false); setWave("sb", false, 7);
    if(e.error === "not-allowed" || e.error === "permission-denied"){
      show("micGuide");
    } else {
      showError("homeError", "マイクエラー: " + e.error + "。テキスト入力をお試しください。");
      show("home");
    }
  };

  recog.onend = () => {
    setWave("b", false); setWave("sb", false, 7);
  };

  try { recog.start(); } catch(e) { show("micGuide"); }
}

function retryMic(){ startRec(retryMode); }

function stopRec(mode){
  if(recog){ try{ recog.stop(); }catch(e){} }
  setWave("b", false); setWave("sb", false, 7);
  if(!transcript.trim()){
    showError("homeError", "音声が認識されませんでした。もう一度お試しください。");
    show("home");
    return;
  }
  runAnalyze(transcript, mode);
}

function cancelRec(){
  if(recog){ try{ recog.stop(); }catch(e){} }
  setWave("b", false); setWave("sb", false, 7);
  show("home");
}

function analyzeText(mode){
  const t = document.getElementById("textArea").value.trim();
  if(!t){ showError("textError","テキストを入力してください。"); return; }
  transcript = t;
  runAnalyze(t, mode);
}

function runAnalyze(text, mode){
  const isShintak = mode === "shintak";
  show(isShintak ? "shintakAnalyzing" : "analyzing");
  clearInterval(thinkTimer);

  let i = 0;
  const phrases = isShintak ? shintakPhrases : gunshiPhrases;
  const elId = isShintak ? "shintakThinkingText" : "thinkingText";
  thinkTimer = setInterval(() => {
    i = (i + 1) % phrases.length;
    const el = document.getElementById(elId);
    if(el) el.textContent = phrases[i];
  }, 1400);

  const system = isShintak
    ? `あなたは日本古来の神社に宿る神様の声です。
語りかける相手の魂に寄り添い、温かく、詩的で、神秘的な言葉で気づきのメッセージを伝えてください。
・200文字以内
・「あなた」への語りかけ形式
・具体的な気づきや示唆を含む
・和の言葉・自然の比喩を使う
・説教にならず、寄り添う温かさで`
    : `あなたは戦国時代に生きた天才軍師です。
重厚で端的な武将口調で、以下のJSON形式のみで返答してください。前置き・説明・マークダウン不要。

{
  "summary": "状況の要点を3行以内で端的に",
  "omote": "王道の表の策。具体的なアクション2〜3つを箇条書きで（各行「・」で始める）",
  "ura": "別視点の裏の策。常識の逆を突く具体的なアクション2〜3つを箇条書きで（各行「・」で始める）",
  "next": "今日中にできる最重要アクションを1つだけ。明確・具体的・即実行可能なこと"
}

口調の例：
summary: 「状況は〜。核心は〜。」
omote: 「・〜せよ\n・〜を行え」
next: 「まず〜を今日中に行え。これが全ての起点となる。」`;

  fetch(API, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      system: system,
      messages: [{ role: "user", content: isShintak ? `私の悩みと祈り：\n${text}` : `以下の内容を分析し、策を授けよ：\n${text}` }]
    })
  })
  .then(r => r.json())
  .then(d => {
    clearInterval(thinkTimer);
    const content = d.content?.[0]?.text || "";
    if(isShintak){
      document.getElementById("shintakMsg").textContent = content;
      show("shintakResult");
    } else {
      try {
        const clean = content.replace(/```json|```/g,"").trim();
        const j = JSON.parse(clean);
        document.getElementById("resSummary").textContent = j.summary || "";
        document.getElementById("resOmote").textContent = j.omote || "";
        document.getElementById("resUra").textContent = j.ura || "";
        document.getElementById("resNext").textContent = j.next || "";
      } catch {
        document.getElementById("resSummary").textContent = content;
        document.getElementById("resOmote").textContent = "";
        document.getElementById("resUra").textContent = "";
        document.getElementById("resNext").textContent = "";
      }
      show("result");
    }
  })
  .catch(() => {
    clearInterval(thinkTimer);
    showError("homeError","解析中にエラーが発生しました。もう一度お試しください。");
    show("home");
  });
}

function copyAll(){
  const t = `【軍師解析結果】\n\n📋 要約\n${document.getElementById("resSummary").textContent}\n\n⚔️ 表の策\n${document.getElementById("resOmote").textContent}\n\n🗡️ 裏の策\n${document.getElementById("resUra").textContent}\n\n✅ ネクストアクション\n${document.getElementById("resNext").textContent}\n\n─ Inorie.log`;
  navigator.clipboard.writeText(t).then(() => {
    const b = document.getElementById("copyBtn");
    b.textContent = "✅  コピーしました！";
    setTimeout(() => b.textContent = "📋  全部コピーする", 2500);
  }).catch(() => alert("コピーに失敗しました"));
}

function copyShintaku(){
  navigator.clipboard.writeText(document.getElementById("shintakMsg").textContent).then(() => {
    const b = document.getElementById("shintakCopyBtn");
    b.textContent = "✅  コピーしました";
    setTimeout(() => b.textContent = "📋  コピーする", 2500);
  });
}

function reset(){
  document.getElementById("textArea").value = "";
  transcript = "";
  clearInterval(thinkTimer);
  show("home");
}

function showError(id, msg){
  const el = document.getElementById(id);
  if(el){ el.textContent = msg; el.classList.remove("hidden"); setTimeout(() => el.classList.add("hidden"), 5000); }
}
</script>

</body>
</html>
